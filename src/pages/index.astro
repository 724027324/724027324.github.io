---
import PhotoMosaic from "../components/PhotoMosaic.astro";
import PostCard from "../components/PostCard.astro";
import homeSettings from "../data/home.json";
import BaseLayout from "../layouts/BaseLayout.astro";
import { getPosts } from "../lib/posts";

const latestPosts = (await getPosts()).slice(0, 3);
---

<BaseLayout title="yyb 的 Blog" description="记录 yyb 现场经验、材料观察、项目复盘和个人观点。">
  {
    homeSettings.showHero && (
      <section class="hero">
        <div class="hero-copy">
          <p class="eyebrow">{homeSettings.eyebrow}</p>
          <h1>{homeSettings.title}</h1>
          <p class="lede">{homeSettings.description}</p>
          <div class="hero-actions">
            <a class="button" href={homeSettings.primaryButtonUrl}>
              {homeSettings.primaryButtonLabel}
            </a>
            <a class="text-link" href={homeSettings.secondaryButtonUrl}>
              {homeSettings.secondaryButtonLabel}
            </a>
          </div>
        </div>
        <PhotoMosaic images={homeSettings.images} />
      </section>
    )
  }

  <section class="intro-band">
    <div>
      <p class="eyebrow">关于这个 Blog</p>
      <h2>把现场经验从零散印象变成可回看的记录。</h2>
    </div>
    <p>
      后续可以把你自己拍摄的 yyb 照片上传到后台，用每篇文章串起观察、观点和项目复盘。
    </p>
  </section>

  <section class="section">
    <div class="section-heading">
      <div>
        <p class="eyebrow">Latest Notes</p>
        <h2>最新文章</h2>
      </div>
      <a class="text-link" href="/blog/">全部文章</a>
    </div>
    {
      latestPosts.length > 0 ? (
        <div class="post-grid">
          {latestPosts.map((post) => <PostCard post={post} />)}
        </div>
      ) : (
        <p class="empty-state">暂无文章。你可以进入后台发布第一篇内容。</p>
      )
    }
  </section>
</BaseLayout>
