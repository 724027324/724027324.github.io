---
import { getCollection } from "astro:content";
import PhotoMosaic from "../components/PhotoMosaic.astro";
import PostCard from "../components/PostCard.astro";
import BaseLayout from "../layouts/BaseLayout.astro";

const posts = (await getCollection("posts")).sort(
  (a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime(),
);
const latestPosts = posts.slice(0, 3);
---

<BaseLayout title="yyb 的 Blog" description="记录 yyb 现场经验、材料观察、项目复盘和个人观点。">
  <section class="hero">
    <div class="hero-copy">
      <p class="eyebrow">现场照片 / 经验记录 / 个人观点</p>
      <h1>用图片记录 yyb 项目里的判断细节</h1>
      <p class="lede">
        这里不是产品手册，而是一份长期更新的个人笔记：材料到场、施工边角、项目沟通和复盘，都值得被认真记录。
      </p>
      <div class="hero-actions">
        <a class="button" href="/blog/">查看文章</a>
        <a class="text-link" href="/about/">了解写作目的</a>
      </div>
    </div>
    <PhotoMosaic />
  </section>

  <section class="intro-band">
    <div>
      <p class="eyebrow">关于这个 Blog</p>
      <h2>把现场经验从零散印象变成可回看的记录。</h2>
    </div>
    <p>
      后续可以把你自己拍摄的 yyb 照片上传到后台，用每篇文章串起观察、观点和项目复盘。
    </p>
  </section>

  <section class="section">
    <div class="section-heading">
      <div>
        <p class="eyebrow">Latest Notes</p>
        <h2>最新文章</h2>
      </div>
      <a class="text-link" href="/blog/">全部文章</a>
    </div>
    <div class="post-grid">
      {latestPosts.map((post) => <PostCard post={post} />)}
    </div>
  </section>
</BaseLayout>
