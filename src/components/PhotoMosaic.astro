---
interface Props {
  images: string[];
}

const { images } = Astro.props;
const displayImages = images.slice(0, 3);
---

<div class="photo-mosaic" aria-label="yyb 现场图片拼贴">
  {
    displayImages.map((src, index) => (
      <img class={index === 0 ? "mosaic-large" : undefined} src={src} alt="" loading="eager" />
    ))
  }
</div>
